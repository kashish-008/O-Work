/* Section 7 stacked cards effect */
.completeinfastructure {
  padding-top: 103px;
  padding-bottom: 140px;
  position: relative;
}

.completeinfastructureheading {
  text-align: center;
  max-width: 824px;
  margin: auto;
  margin-bottom: 50px;
}

.flexdirexction {
  display: flex;
  flex-direction: column;
  gap: 50px; /* spacing between card wrappers */
  position: relative;
}

/* Each card wrapper */
.completestructurecontent {
  position: relative;
  height: 420px; /* approximate card height */
}

/* Inner card content sticky for stack effect */
.completeinnercontent {
  display: flex;
  gap: 57px;
  align-items: flex-start;
  position: sticky;
  top: 100px; /* distance from top while scrolling */
  z-index: 1;
  background: white; /* overlay effect */
  border-radius: 20px;
  padding: 20px;
  box-shadow: 0px 8px 20px rgba(0,0,0,0.1);
  opacity: 1;
  transition: opacity 0.3s ease;
}

/* Stack order: higher z-index for next cards */
.completestructurecontent:nth-child(1) .completeinnercontent { z-index: 10; }
.completestructurecontent:nth-child(2) .completeinnercontent { z-index: 20; }
.completestructurecontent:nth-child(3) .completeinnercontent { z-index: 30; }

/* Left image */
.leftsidecomplete {
  width: 400px;
  flex-shrink: 0;
}

.leftsidecomplete img {
  width: 100%;
  display: block;
  border-radius: 15px;
}

/* Right content */
.rightsidecomplete {
  flex: 1;
}

.rightsidecomplete>h5 {
  color: #155DFC;
  margin-bottom: 9px;
}

.rightsidecomplete>h6 {
  font-family: "Satoshi";
  font-size: 22px;
  margin-bottom: 0px;
  line-height: 1.6;
  color: #747474;
}

/* Responsive */
@media (max-width: 992px) {
  .completeinnercontent {
    flex-direction: column;
    gap: 20px;
    text-align: center;
    top: 50px;
  }
  .leftsidecomplete { width: 100%; }
}